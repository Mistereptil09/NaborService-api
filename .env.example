# ============================================================
# Nabor Services — .env.example
# Copier en .env à la racine du projet.
# Ce fichier est injecté dans les containers via env_file dans compose.yml
# NE PAS committer .env — uniquement .env.example
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
qrcodeurl=http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────────
# Utiliser "localhost" pour le dev local hors Docker. Surchargé en "postgres" dans compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nabor
POSTGRES_PASSWORD=nabor_secret
POSTGRES_DB=nabor_db

# ── MongoDB ──────────────────────────────────────────────────
# Utiliser "localhost" pour le dev local hors Docker. Surchargé en "mongo" dans compose.yml.
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=nabor
MONGO_INITDB_ROOT_PASSWORD=nabor_secret
MONGO_DB=nabor_db

# ── Neo4j ────────────────────────────────────────────────────
# Utiliser "localhost" pour le dev local hors Docker. Surchargé en "neo4j" dans compose.yml.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nabor_secret

# ── Redis ────────────────────────────────────────────────────
# Utiliser "localhost" pour le dev local hors Docker. Surchargé en "redis" dans compose.yml.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=nabor_redis_secret

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=dev-secret-change-in-production-minimum-64-chars-xxxxxxxxxxxxxxxxxxx

# ── Chiffrement AES (TOTP secrets, clés groupes messagerie) ──
AES_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── DSL Service ──────────────────────────────────────────────
DSL_SERVICE_URL=http://dsl-service:8000

# ── SMTP (dev = Mailpit, prod = Brevo) ───────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@nabor.fr
# Dev Mailpit : laisser vide. Prod Brevo : SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587, user/pass remplis, SMTP_SECURE=false (STARTTLS).
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# ── Frontend (liens dans les emails) ─────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY= sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder