<h1 style="margin:0 0 16px;font-size:20px;color:#14213d;">Vous avez une nouvelle notification</h1>

<p style="margin:0 0 16px;">Bonjour{{#if firstName}} {{firstName}}{{/if}},</p>

<p style="margin:0 0 16px;">
  Une nouvelle activit&eacute; vous concernant a eu lieu sur Nabor.
</p>

{{#if status}}
<p style="margin:0 0 16px;padding:12px 16px;background-color:#f4f5f7;border-left:3px solid #ff6b00;color:#444444;">
  <strong>Statut&nbsp;:</strong> {{status}}
</p>
{{/if}}
{{#if reason}}
<p style="margin:0 0 16px;padding:12px 16px;background-color:#f4f5f7;border-left:3px solid #ff6b00;color:#444444;">
  <strong>D&eacute;tail&nbsp;:</strong> {{reason}}
</p>
{{/if}}

{{#if event_id}}
<p style="margin:0 0 24px;text-align:center;">
  <a href="{{frontendUrl}}/events/{{event_id}}" style="display:inline-block;background-color:#ff6b00;color:#ffffff;text-decoration:none;font-weight:bold;padding:12px 28px;border-radius:6px;">
    Ouvrir dans l'application
  </a>
</p>
{{/if}}

<p style="margin:0;color:#666666;font-size:13px;">
  Retrouvez tous les d&eacute;tails directement dans l'application Nabor.
</p>
